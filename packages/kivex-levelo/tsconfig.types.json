{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,

    "declaration": true,
    "emitDeclarationOnly": true,

    "rootDir": "./src",
    "outDir": "./dist",

    "module": "ESNext",
    "target": "ESNext",
    "moduleResolution": "Bundler",
    "skipLibCheck": true
  },
  "include": ["src/**/*"]
}