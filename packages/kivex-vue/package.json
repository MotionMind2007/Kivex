{
  "name": "kivex-vue",
  "version": "1.3.0",
  "description": "The official Vue component library for Kivex Icons.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "scripts": {
    "generate": "tsx scripts/build.ts",
    "build": "tsup && vue-tsc --project tsconfig.build.json",
    "prepublishOnly": "pnpm run generate && pnpm run build"
  },
  "keywords": [
    "Vue",
    "Vue3",
    "kivex",
    "kivex-icons",
    "kivex-vue",
    "open-source",
    "icon-library",
    "dynamic-icons",
    "icon",
    "ui"
  ],
  "author": "MotionMind2007",
  "license": "MIT",
  "devDependencies": {
    "esbuild-plugin-vue": "^0.2.4",
    "vue-tsc": "^3.3.7",
    "unplugin-vue": "^7.2.0"
  },
  "peerDependencies": {
    "vue": "^3.5.39"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MotionMind2007/Kivex.git"
  },
  "bugs": {
    "url": "https://github.com/MotionMind2007/Kivex/issues"
  },
  "homepage": "https://github.com/MotionMind2007/Kivex#readme"
}
