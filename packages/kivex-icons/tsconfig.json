{
    "compilerOptions": {
        "target": "ES2022",
        "jsx": "react-jsx",
        "strict": true,
        "moduleResolution": "bundler",
        "declaration": true,
        "declarationMap": true,
        "esModuleInterop": true,
        "sourceMap": true,
        "outDir": "./dist",
        "skipDefaultLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "isolatedModules": true,
        "preserveSymlinks": true,
    }
}