{
  "name": "kivex-icons",
  "version": "1.1.0",
  "description": "A pixel-perfect open-source SVG icon library for JavaScript.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "generate": "tsx scripts/build.ts",
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run generate && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MotionMind2007/Kivex.git"
  },
  "keywords":  ["motion-icons", "javascript", "typescript", "kivex", "kivex-icons", "open-source", "icon-library", "dynamic-icons", "icon", "ui"],
  "author": "MotionMind2007",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
