{
  "name": "kivex-icons",
  "version": "1.2.0",
  "description": "A pixel-perfect open-source SVG icon library for JavaScript.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "scripts": {
    "generate": "tsx scripts/build.ts",
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "pnpm run generate && pnpm run build"
  },
  "keywords": [
    "motion-icons",
    "javascript",
    "typescript",
    "kivex",
    "kivex-icons",
    "open-source",
    "icon-library",
    "dynamic-icons",
    "icon",
    "ui"
  ],
  "author": "MotionMind2007",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MotionMind2007/Kivex.git"
  },
  "bugs": {
    "url": "https://github.com/MotionMind2007/Kivex/issues"
  },
  "homepage": "https://github.com/MotionMind2007/Kivex#readme"
}
