{
  "name": "kivex-icons",
  "version": "1.0.0",
  "description": "A pixel-perfect, dynamic, and open-source icon library package for web and javascript applications.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "generate": "tsx scripts/build.ts",
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MotionMind2007/Kivex"
  },
  "keywords":  ["icons", "svg", "motion-icons", "vanilla-js", "javascript", "kivex", "kivex-icons", "open-source", "icon-library", "dynamic-icons"],
  "author": "MotionMind2007",
  "license": "MIT"
}
