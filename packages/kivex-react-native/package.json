{
  "name": "kivex-react-native",
  "version": "1.3.0",
  "description": "Kivex icon library for React Native",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "generate": "tsx generator/build.ts",
    "watch": "tsx generator/watch.ts",
    "build": "tsup",
    "prepublishOnly": "pnpm run generate && pnpm run build"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-native": ">=0.64.0",
    "react-native-svg": ">=15.15.5"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.11.0",
    "chokidar": "^3.6.0",
    "fast-glob": "^3.3.2",
    "fs-extra": "^11.2.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.23.1",
    "typescript": "^5.3.3"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "react-native",
    "icons",
    "svg",
    "kivex"
  ],
  "license": "MIT",
  "type": "module",
  "sideEffects": false
}
