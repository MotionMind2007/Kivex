{
    "name": "kivex-react",
    "version": "1.2.0",
    "description": "The official React component library for Kivex Icons.",
    "type": "module",
    "license": "MIT",
    "keywords":  [
        "react",
        "svg",
        "icons",
        "typescript",
        "kivex",
        "kivex-react",
        "icon-library",
        "open-source",
        "pixel-perfect",
        "tree-shakable"
    ],
    "author": "MotionMind2007",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/MotionMind2007/Kivex.git"
    },
    "bugs": {
        "url": "https://github.com/MotionMind2007/Kivex/issues"
    },
    "homepage": "https://github.com/MotionMind2007/Kivex#readme",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        }
    },
    "sideEffects": false,
    "publishConfig": {
    "access": "public"
    },
    "peerDependencies": {
        "react": "^19.2.7"
    },
    "scripts": {
        "generate": "tsx scripts/build.ts",
        "watch": "tsx scripts/watch.ts",
        "build": "tsup",
        "dev": "tsup --watch",
        "test": "vitest run",
        "prepublishOnly": "npm run generate && npm run build"
    }
}
