{
    "compilerOptions": {
        "ignoreDeprecations": "6.0",
        "baseUrl": ".",
        "target": "ES2022",
        "module": "ESNext",
        "jsx": "react-jsx",
        "declaration": true,
        "declarationMap": true,
        "strict": true,
        "moduleResolution": "bundler",
        "erasableSyntaxOnly": true,
        "skipLibCheck": true,
        "isolatedModules": true
    },
    "include": [
        "src",
        "scripts"
    ]
}